.swiper-wrap {
  position: relative;
}

.swiper {
  height: 750rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 商品信息 */
.info-card {
  margin-top: -20rpx;
  border-radius: 24rpx 24rpx 0 0;
  position: relative;
  z-index: 1;
}

.price-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.price-row .tag {
  margin-left: 16rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

/* 描述 */
.desc-card {
  margin-top: 0;
}

.desc-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.desc-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 数量 */
.quantity-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quantity-label {
  font-size: 28rpx;
  color: #333;
}

.quantity-stepper {
  display: flex;
  align-items: center;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  background: #fafafa;
}

.stepper-btn.disabled {
  color: #ccc;
  background: #f5f5f5;
}

.stepper-value {
  width: 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.btn-cart {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffb347, #ffcc80);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-right: 20rpx;
}

.btn-buy {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff5777, #ff8a80);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 44rpx;
}
