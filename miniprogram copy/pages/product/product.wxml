<view class="container" wx:if="{{product}}">
  <!-- 轮播图 -->
  <view class="swiper-wrap">
    <swiper class="swiper" indicator-dots indicator-color="#ddd" indicator-active-color="#ff5777" autoplay circular bindchange="onSwiperChange">
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="swiper-img" data-index="{{index}}" bindtap="onPreviewImage" />
      </swiper-item>
    </swiper>
    <view class="image-counter">{{currentImageIndex + 1}}/{{product.images.length}}</view>
  </view>

  <!-- 商品信息 -->
  <view class="info-card card">
    <view class="price-row">
      <text class="price">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{product.price}}</text>
      </text>
      <text class="original-price" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
      <view class="tag tag-red" wx:if="{{product.originalPrice}}">
        省{{(product.originalPrice - product.price).toFixed(0)}}元
      </view>
    </view>
    <view class="product-name">{{product.name}}</view>
    <view class="meta-row">
      <text class="sales">已售 {{product.sales > 10000 ? (product.sales / 10000).toFixed(1) + '万' : product.sales}}</text>
      <text class="stock">库存 {{product.stock}} 件</text>
    </view>
  </view>

  <!-- 商品描述 -->
  <view class="desc-card card">
    <view class="desc-title">商品详情</view>
    <view class="desc-content">{{product.desc}}</view>
  </view>

  <!-- 数量选择 -->
  <view class="quantity-card card">
    <text class="quantity-label">购买数量</text>
    <view class="quantity-stepper">
      <view class="stepper-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onMinus">−</view>
      <view class="stepper-value">{{quantity}}</view>
      <view class="stepper-btn {{quantity >= product.stock ? 'disabled' : ''}}" bindtap="onPlus">+</view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="btn-cart" bindtap="onAddToCart">加入购物车</view>
    <view class="btn-buy" bindtap="onBuyNow">立即购买</view>
  </view>

  <!-- 底部安全区占位 -->
  <view style="height: 120rpx;"></view>
</view>
