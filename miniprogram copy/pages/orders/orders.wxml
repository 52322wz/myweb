<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >{{item.label}}</view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{!isEmpty}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="orderId">
      <view class="order-header">
        <text class="order-id">订单号：{{item.orderId}}</text>
        <text class="order-status {{item.status}}">
          {{item.status === 'pending' ? '待付款' : '已完成'}}
        </text>
      </view>
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="product">
          <image class="item-img" src="{{product.image}}" mode="aspectFill" />
          <view class="item-info">
            <view class="item-name text-ellipsis">{{product.name}}</view>
            <view class="item-price">
              <text class="price">¥{{product.price}}</text>
              <text class="qty">×{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <text class="order-total">合计：<text class="price">¥{{item.totalPrice.toFixed(2)}}</text></text>
      </view>
      <view class="order-actions" wx:if="{{item.status === 'pending'}}">
        <view class="btn-pay" data-order-id="{{item.orderId}}" bindtap="onPay">立即付款</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
