<view class="container">
  <!-- 用户头部 -->
  <view class="user-header">
    <view class="user-info" bindtap="onGetUserInfo">
      <image class="avatar" src="{{userInfo.avatarUrl || ''}}" mode="aspectFill" wx:if="{{userInfo}}" />
      <view class="avatar-placeholder" wx:else>👤</view>
      <view class="user-text">
        <view class="user-name">{{userInfo ? userInfo.nickName : '点击登录'}}</view>
        <view class="user-desc">{{userInfo ? '欢迎回来' : '登录后可同步数据'}}</view>
      </view>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section card">
    <view class="section-header flex-between">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="onGoOrders" data-status="all">全部订单 ›</text>
    </view>
    <view class="order-grid">
      <view class="order-item" bindtap="onGoOrders" data-status="all">
        <text class="order-icon">📋</text>
        <text class="order-label">全部</text>
        <text class="order-count" wx:if="{{orderCounts.all > 0}}">{{orderCounts.all}}</text>
      </view>
      <view class="order-item" bindtap="onGoOrders" data-status="pending">
        <text class="order-icon">💳</text>
        <text class="order-label">待付款</text>
        <text class="order-count pending" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</text>
      </view>
      <view class="order-item" bindtap="onGoOrders" data-status="completed">
        <text class="order-icon">✅</text>
        <text class="order-label">已完成</text>
        <text class="order-count completed" wx:if="{{orderCounts.completed > 0}}">{{orderCounts.completed}}</text>
      </view>
    </view>
  </view>

  <!-- 服务入口 -->
  <view class="service-section card">
    <view class="service-item" bindtap="onManageAddress">
      <text class="service-icon">📍</text>
      <text class="service-label">收货地址管理</text>
      <text class="service-arrow">›</text>
    </view>
    <view class="service-item" bindtap="onContact">
      <text class="service-icon">💬</text>
      <text class="service-label">联系客服</text>
      <text class="service-arrow">›</text>
    </view>
    <view class="service-item" bindtap="onAbout">
      <text class="service-icon">ℹ️</text>
      <text class="service-label">关于我们</text>
      <text class="service-arrow">›</text>
    </view>
  </view>
</view>
