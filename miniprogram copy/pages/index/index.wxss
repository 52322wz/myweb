.container {
  padding-top: 20rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 0 20rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f5f5f5;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #bbb;
  padding: 4rpx 8rpx;
}

/* 分类栏 */
.category-bar {
  white-space: nowrap;
  padding: 0 20rpx 16rpx;
  display: flex;
}

.category-item {
  display: inline-block;
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  background: #fff;
  transition: all 0.2s;
}

.category-item.active {
  background: linear-gradient(135deg, #ff5777, #ff8a80);
  color: #fff;
  font-weight: bold;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}

.product-col {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}
