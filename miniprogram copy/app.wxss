/* ========== 全局样式 ========== */

page {
  --primary: #ff5777;
  --primary-dark: #e84a65;
  --bg: #f5f5f5;
  --white: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #eeeeee;
  --red: #ff5777;
  --orange: #ff8c00;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 弹性布局 */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.flex-1 {
  flex: 1;
}

/* 文字 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-center {
  text-align: center;
}
.text-primary {
  color: #ff5777;
}
.text-secondary {
  color: #666;
}
.text-light {
  color: #999;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #ff5777, #ff8a80);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-outline {
  background: #fff;
  color: #ff5777;
  border: 2rpx solid #ff5777;
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  text-align: center;
}

/* 价格 */
.price {
  color: #ff5777;
  font-weight: bold;
}
.price-symbol {
  font-size: 24rpx;
}
.price-value {
  font-size: 36rpx;
}
.original-price {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.tag-red {
  background: #fff0f0;
  color: #ff5777;
  border: 1rpx solid #ffd4d4;
}
