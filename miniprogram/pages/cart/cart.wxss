.cart-item {
  display: flex; align-items: center;
  background: #FFFFFF;
  padding: 20rpx; margin: 0 20rpx 12rpx;
  border-radius: 18rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03);
}

.checkbox { margin-right: 16rpx; }
.check-icon { font-size: 40rpx; color: #C7C7CC; }
.check-icon.checked { color: #007AFF; }

.item-img {
  width: 160rpx; height: 160rpx; border-radius: 14rpx;
  background: #F2F2F7; flex-shrink: 0;
}

.item-info {
  flex: 1; margin-left: 16rpx;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 160rpx;
}

.item-name { font-size: 28rpx; color: #1C1C1E; line-height: 1.4; font-weight: 500; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }
.item-bottom .price { font-size: 30rpx; }

.stepper { display: flex; align-items: center; }
.stepper-btn {
  width: 50rpx; height: 50rpx;
  background: #F2F2F7; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #007AFF; font-weight: 500;
}
.stepper-value { width: 60rpx; text-align: center; font-size: 26rpx; color: #1C1C1E; font-weight: 600; }

.delete-btn { padding: 10rpx; font-size: 30rpx; color: #C7C7CC; margin-left: 4rpx; }

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  padding: 16rpx 24rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.select-all { display: flex; align-items: center; font-size: 26rpx; color: #1C1C1E; margin-right: 20rpx; }
.select-all .check-icon { margin-right: 8rpx; }

.total-wrap { flex: 1; text-align: right; margin-right: 16rpx; }
.total-label { font-size: 26rpx; color: #8E8E93; }
.total-wrap .price-value { font-size: 36rpx; }

.btn-checkout {
  padding: 20rpx 44rpx;
  background: #007AFF; color: #fff;
  font-size: 28rpx; font-weight: 600; border-radius: 24rpx;
}
.btn-checkout.disabled { background: #C7C7CC; opacity: 0.6; }
