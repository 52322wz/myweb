.admin-header {
  display: flex; align-items: center; justify-content: space-between;
  background: #1C1C1E;
  padding: 24rpx 28rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.admin-info { display: flex; align-items: center; }
.admin-icon { font-size: 40rpx; margin-right: 16rpx; }
.admin-label { display: block; font-size: 30rpx; font-weight: 700; color: #fff; }
.admin-hint { display: block; font-size: 22rpx; color: rgba(255,255,255,0.55); }

.header-actions { display: flex; gap: 16rpx; }
.action-btn {
  font-size: 26rpx; color: #fff; font-weight: 500;
  padding: 10rpx 24rpx; background: rgba(255,255,255,0.15); border-radius: 18rpx;
}
.action-btn.logout { color: #FF453A; background: rgba(255,69,58,0.15); }

/* Tab */
.tab-bar {
  display: flex; background: #FFFFFF;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.04);
}
.tab-item {
  flex: 1; text-align: center;
  padding: 22rpx 0; font-size: 26rpx; color: #8E8E93; font-weight: 500;
}
.tab-item.active { color: #007AFF; font-weight: 700; border-bottom: 3rpx solid #007AFF; }

/* 订单卡片 */
.order-card { margin: 16rpx 20rpx; padding: 0; }
.order-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 20rpx 14rpx;
  border-bottom: 1rpx solid #F2F2F7;
}
.buyer-name { font-size: 28rpx; font-weight: 700; color: #1C1C1E; }
.order-status { font-size: 24rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 20rpx; }
.order-status.pending { color: #FF9500; background: #FFF5E6; }
.order-status.completed { color: #34C759; background: #EBFFF0; }

.order-body { padding: 0 20rpx; }
.order-item { display: flex; align-items: center; padding: 12rpx 0; }
.order-item + .order-item { border-top: 1rpx solid #FAFAFA; }

.item-img {
  width: 80rpx; height: 80rpx; border-radius: 10rpx;
  background: #F2F2F7; flex-shrink: 0;
}
.item-info { flex: 1; margin-left: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.item-name { font-size: 24rpx; color: #1C1C1E; flex: 1; }
.item-price { font-size: 24rpx; color: #8E8E93; flex-shrink: 0; margin-left: 12rpx; }

.order-footer {
  display: flex; justify-content: space-between; padding: 16rpx 20rpx;
  border-top: 1rpx solid #F2F2F7;
}
.order-time { font-size: 22rpx; color: #C7C7CC; }
.order-total { font-size: 26rpx; color: #1C1C1E; }
.order-total .price { font-size: 30rpx; font-weight: 700; }

.order-actions { display: flex; justify-content: flex-end; gap: 14rpx; padding: 0 20rpx 20rpx; }
.btn-detail {
  padding: 12rpx 28rpx; font-size: 24rpx; font-weight: 500;
  color: #007AFF; background: #EBF5FF; border-radius: 20rpx;
}
.btn-complete {
  padding: 12rpx 28rpx; font-size: 24rpx; font-weight: 500;
  color: #fff; background: #007AFF; border-radius: 20rpx;
}

/* Admin empty */
.admin-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 180rpx 0; }
.admin-empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.5; }
.admin-empty-text { font-size: 28rpx; color: #8E8E93; font-weight: 500; }
