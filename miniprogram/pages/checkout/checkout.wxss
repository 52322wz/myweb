.address-card { cursor: pointer; }
.address-content { line-height: 1.6; }
.address-header { display: flex; align-items: center; margin-bottom: 8rpx; }
.address-name { font-size: 30rpx; font-weight: 600; color: #1C1C1E; margin-right: 24rpx; }
.address-phone { font-size: 26rpx; color: #8E8E93; }
.address-detail { font-size: 26rpx; color: #8E8E93; }

.address-empty { display: flex; align-items: center; font-size: 28rpx; color: #8E8E93; }
.address-icon { margin-right: 12rpx; font-size: 36rpx; }
.address-arrow { margin-left: auto; font-size: 36rpx; color: #C7C7CC; }

/* 商品清单 */
.card-title {
  font-size: 30rpx; font-weight: 700; color: #1C1C1E;
  margin-bottom: 20rpx; padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.item-row { display: flex; align-items: center; padding: 12rpx 0; }
.item-row + .item-row { border-top: 1rpx solid #F2F2F7; }

.item-img {
  width: 100rpx; height: 100rpx; border-radius: 12rpx;
  background: #F2F2F7; flex-shrink: 0;
}

.item-info {
  flex: 1; margin-left: 16rpx;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 100rpx;
}

.item-name { font-size: 26rpx; color: #1C1C1E; }
.item-price { display: flex; align-items: center; justify-content: space-between; }
.item-price .price { font-size: 28rpx; }
.qty { font-size: 24rpx; color: #8E8E93; }

/* 价格 */
.price-card { margin-top: 0; }
.price-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; font-size: 26rpx; color: #8E8E93;
}
.price-row.total {
  border-top: 1rpx solid #E5E5EA;
  padding-top: 18rpx; margin-top: 10rpx;
}
.price-row .price { font-size: 28rpx; color: #1C1C1E; }
.total-price { font-size: 36rpx !important; font-weight: 700; }
.free { color: #34C759; font-size: 26rpx; font-weight: 500; }

/* 底部 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  padding: 16rpx 24rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.total-wrap { flex: 1; }
.total-label { font-size: 26rpx; color: #8E8E93; }
.total-wrap .price-value { font-size: 38rpx; }

.btn-submit {
  padding: 22rpx 48rpx;
  background: #007AFF; color: #fff;
  font-size: 30rpx; font-weight: 600; border-radius: 24rpx;
}
