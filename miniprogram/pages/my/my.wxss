/* 用户头部 */
.user-header {
  background: #FFFFFF;
  padding: 48rpx 36rpx 40rpx;
  margin-bottom: 20rpx;
}

.user-info { display: flex; align-items: center; }

.avatar-placeholder {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: #F2F2F7;
  display: flex; align-items: center; justify-content: center;
  font-size: 52rpx;
}

.user-text { margin-left: 24rpx; }
.user-name { font-size: 38rpx; font-weight: 700; color: #1C1C1E; margin-bottom: 6rpx; }
.user-desc { font-size: 24rpx; color: #8E8E93; }

/* 订单区域 */
.section-header { margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #1C1C1E; }
.section-more { font-size: 24rpx; color: #007AFF; }

.order-grid { display: flex; justify-content: space-around; padding: 8rpx 0; }
.order-item { display: flex; flex-direction: column; align-items: center; position: relative; }
.order-icon { font-size: 44rpx; margin-bottom: 10rpx; }
.order-label { font-size: 24rpx; color: #8E8E93; }

.order-count {
  position: absolute; top: -10rpx; right: -20rpx;
  min-width: 34rpx; height: 34rpx; line-height: 34rpx; text-align: center;
  background: #FF3B30; color: #fff;
  font-size: 20rpx; font-weight: 600; border-radius: 17rpx; padding: 0 8rpx;
}
.order-count.pending { background: #FF9500; }
.order-count.completed { background: #34C759; }

/* 服务列表 */
.service-section { margin-top: 0; }
.service-item {
  display: flex; align-items: center;
  padding: 28rpx 0;
}
.service-item + .service-item { border-top: 1rpx solid #F2F2F7; }
.service-icon { font-size: 40rpx; margin-right: 20rpx; }
.service-label { flex: 1; font-size: 28rpx; color: #1C1C1E; }
.service-arrow { font-size: 34rpx; color: #C7C7CC; }

/* 退出登录 */
.logout-section { padding: 40rpx; }
.btn-logout {
  width: 100%; height: 88rpx; line-height: 88rpx; text-align: center;
  background: #FFFFFF; color: #FF3B30;
  font-size: 30rpx; font-weight: 500;
  border-radius: 20rpx;
}
