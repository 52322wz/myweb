.tab-bar {
  display: flex; background: #FFFFFF;
  padding: 0 20rpx; box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03);
}

.tab-item {
  flex: 1; text-align: center;
  padding: 26rpx 0; font-size: 28rpx; color: #8E8E93; font-weight: 500;
  position: relative;
}

.tab-item.active { color: #007AFF; font-weight: 700; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 40rpx; height: 4rpx; background: #007AFF; border-radius: 2rpx;
}

/* 订单卡片 */
.order-card { margin: 16rpx 20rpx; padding: 0; }

.order-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 20rpx 14rpx;
  border-bottom: 1rpx solid #F2F2F7;
}

.order-id { font-size: 24rpx; color: #8E8E93; }
.order-status { font-size: 24rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 20rpx; }
.order-status.pending { color: #FF9500; background: #FFF5E6; }
.order-status.completed { color: #34C759; background: #EBFFF0; }

.order-items { padding: 0 20rpx; }
.order-item { display: flex; align-items: center; padding: 12rpx 0; }
.order-item + .order-item { border-top: 1rpx solid #FAFAFA; }

.item-img {
  width: 80rpx; height: 80rpx; border-radius: 10rpx;
  background: #F2F2F7; flex-shrink: 0;
}

.item-info {
  flex: 1; margin-left: 12rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.item-name { font-size: 24rpx; color: #1C1C1E; flex: 1; }
.item-price { display: flex; align-items: center; gap: 12rpx; }
.item-price .price { font-size: 24rpx; }
.qty { font-size: 22rpx; color: #8E8E93; }

.order-footer {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 20rpx; border-top: 1rpx solid #F2F2F7;
}
.order-time { font-size: 22rpx; color: #C7C7CC; }
.order-total { font-size: 26rpx; color: #1C1C1E; }
.order-total .price { font-size: 28rpx; }

.order-actions { display: flex; justify-content: flex-end; padding: 0 20rpx 20rpx; }
.btn-pay {
  padding: 14rpx 36rpx;
  background: #007AFF; color: #fff;
  font-size: 26rpx; font-weight: 600; border-radius: 22rpx;
}
