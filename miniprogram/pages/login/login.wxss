.login-container {
  min-height: 100vh;
  background: #F2F2F7;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8E8E93;
  font-weight: 400;
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  width: 86%;
}

.role-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 44rpx 36rpx;
  text-align: center;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
  transition: all 0.15s;
}

.role-card:active {
  transform: scale(0.97);
  opacity: 0.8;
}

.role-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.role-title { font-size: 34rpx; font-weight: 700; color: #1C1C1E; margin-bottom: 6rpx; }
.role-desc { font-size: 24rpx; color: #8E8E93; }

/* Modal */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(8rpx);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}

.modal-box {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}

.modal-title {
  font-size: 36rpx; font-weight: 700; color: #1C1C1E;
  text-align: center; margin-bottom: 6rpx;
}
.modal-desc {
  font-size: 24rpx; color: #8E8E93; text-align: center; margin-bottom: 32rpx;
}

.modal-input {
  width: 100%; height: 88rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  padding: 0 24rpx; font-size: 28rpx;
  box-sizing: border-box; margin-bottom: 28rpx;
}

.modal-actions { display: flex; gap: 16rpx; }

.btn-cancel {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: #F2F2F7; color: #1C1C1E; font-size: 28rpx; font-weight: 500;
  border-radius: 44rpx;
}
.btn-confirm {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: #007AFF; color: #fff; font-size: 28rpx; font-weight: 600;
  border-radius: 44rpx;
}
