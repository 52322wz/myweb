.swiper-wrap { position: relative; }
.swiper { height: 750rpx; }
.swiper-img { width: 100%; height: 100%; }

.image-counter {
  position: absolute; right: 20rpx; bottom: 20rpx;
  background: rgba(0,0,0,0.45);
  color: #fff; font-size: 22rpx; font-weight: 500;
  padding: 6rpx 18rpx; border-radius: 30rpx;
}

/* 商品信息 */
.info-card {
  margin-top: -24rpx; border-radius: 28rpx 28rpx 0 0;
  position: relative; z-index: 1;
}

.price-row {
  display: flex; align-items: center; margin-bottom: 14rpx;
}
.price-row .tag { margin-left: 14rpx; }

.product-name {
  font-size: 34rpx; font-weight: 700; color: #1C1C1E;
  line-height: 1.4; margin-bottom: 16rpx;
  letter-spacing: -0.3rpx;
}

.meta-row { display: flex; justify-content: space-between; font-size: 24rpx; color: #8E8E93; }

/* 描述 */
.desc-card { margin-top: 0; }
.desc-title {
  font-size: 30rpx; font-weight: 700; color: #1C1C1E;
  margin-bottom: 16rpx; padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E5EA;
}
.desc-content { font-size: 28rpx; color: #3C3C43; line-height: 1.8; }

/* 数量 */
.quantity-card { display: flex; align-items: center; justify-content: space-between; }
.quantity-label { font-size: 28rpx; color: #1C1C1E; font-weight: 500; }

.quantity-stepper { display: flex; align-items: center; }
.stepper-btn {
  width: 60rpx; height: 60rpx;
  background: #F2F2F7; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx; color: #007AFF; font-weight: 500;
}
.stepper-btn.disabled { color: #C7C7CC; }
.stepper-value {
  width: 80rpx; text-align: center;
  font-size: 30rpx; font-weight: 600; color: #1C1C1E;
}

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  z-index: 100;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.btn-cart {
  flex: 1; height: 84rpx; line-height: 84rpx; text-align: center;
  background: #F2F2F7; color: #007AFF;
  font-size: 28rpx; font-weight: 600; border-radius: 22rpx; margin-right: 16rpx;
}
.btn-buy {
  flex: 1; height: 84rpx; line-height: 84rpx; text-align: center;
  background: #007AFF; color: #fff;
  font-size: 28rpx; font-weight: 600; border-radius: 22rpx;
}
