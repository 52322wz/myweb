.container { padding-top: 16rpx; }

/* 搜索栏 */
.search-bar {
  padding: 0 20rpx 16rpx;
  position: sticky; top: 0; z-index: 10;
  background: #F2F2F7;
}

.search-input-wrap {
  display: flex; align-items: center;
  background: #E5E5EA;
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
}

.search-icon { font-size: 28rpx; margin-right: 10rpx; opacity: 0.5; }

.search-input {
  flex: 1; font-size: 26rpx; color: #1C1C1E;
  background: transparent;
}

.clear-btn {
  font-size: 26rpx; color: #8E8E93;
  width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center;
}

/* 分类栏 */
.category-bar {
  width: 100%;
  white-space: nowrap;
  padding-bottom: 20rpx;
}

.category-bar .flex-row {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  font-size: 26rpx; color: #1C1C1E;
  padding: 12rpx 28rpx; margin-right: 12rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  font-weight: 500;
  transition: all 0.2s;
}

.category-item.active {
  background: #007AFF; color: #fff; font-weight: 600;
}

/* 商品网格 */
.product-grid {
  display: flex; flex-wrap: wrap;
  padding: 0 12rpx;
}

.product-col {
  width: 50%; padding: 8rpx; box-sizing: border-box;
}
